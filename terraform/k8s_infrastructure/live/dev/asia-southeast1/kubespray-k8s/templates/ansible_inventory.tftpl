# Ansible kubespray_k8s main inventory - auto-generated by Terraform
# Used by the ansible_kubespray_k8s playbooks (zsh setup, pre-flight tasks, etc.)
# Groups use Kubespray standard names so all inventories are interchangeable.
# Do not edit manually. Terraform rewrites this file during apply.

[kube_control_plane]
%{ for node in control_plane_nodes ~}
${node.name} ansible_host=${node.public_ip} ip=${node.private_ip}
%{ endfor }

[kube_node]
%{ for node in worker_nodes ~}
${node.name} ansible_host=${node.public_ip} ip=${node.private_ip}
%{ endfor }

[k8s_cluster:children]
kube_control_plane
kube_node

[local]
localhost ansible_connection=local

[all:vars]
ansible_user=${ansible_user}
ansible_ssh_private_key_file=${ansible_ssh_private_key_file}
ansible_python_interpreter=${ansible_python_interpreter}
ansible_ssh_extra_args='${ansible_ssh_extra_args}'
