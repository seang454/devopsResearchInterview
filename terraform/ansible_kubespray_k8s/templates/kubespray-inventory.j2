# Kubespray HA inventory — auto-generated by Ansible
# Topology: stacked etcd (same nodes as control plane)
# See https://docs.ansible.com/ansible/latest/inventory_guide/intro_inventory.html

[kube_control_plane]
{% for instance in gcp_instances.results %}
{% if instance.name is defined and instance.skipped is not defined and instance.name.startswith('master') %}
{{ instance.name }} ansible_host={{ instance.networkInterfaces[0].accessConfigs[0].natIP }}  ip={{ instance.networkInterfaces[0].networkIP }} etcd_member_name={{ instance.name }}
{% endif %}
{% endfor %}

[etcd:children]
kube_control_plane

[kube_node]
{% for instance in gcp_instances.results %}
{% if instance.name is defined and instance.skipped is not defined and instance.name.startswith('worker') %}
{{ instance.name }} ansible_host={{ instance.networkInterfaces[0].accessConfigs[0].natIP }}  ip={{ instance.networkInterfaces[0].networkIP }}
{% endif %}
{% endfor %}

[k8s_cluster:children]
kube_control_plane
kube_node

[calico_rr]

[all:vars]
ansible_user=seang
ansible_ssh_private_key_file=/home/seang/.ssh/id_rsa
ansible_python_interpreter=/usr/bin/python3
ansible_ssh_extra_args='-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'