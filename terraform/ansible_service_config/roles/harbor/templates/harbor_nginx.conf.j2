server {
    listen 80;
    listen [::]:80;
    server_name {{ harbor_hostname }};

    access_log /var/log/nginx/harbor_access.log;
    error_log  /var/log/nginx/harbor_error.log;

    # Allow large uploads for docker images
    client_max_body_size 0;
    chunked_transfer_encoding on;

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        proxy_pass http://127.0.0.1:{{ harbor_http_port }};
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Disable buffering to avoid timeouts during docker push/pull
        proxy_buffering off;
        proxy_request_buffering off;
        
        proxy_read_timeout 900s;
        proxy_connect_timeout 900s;
        proxy_send_timeout 900s;
    }
}
