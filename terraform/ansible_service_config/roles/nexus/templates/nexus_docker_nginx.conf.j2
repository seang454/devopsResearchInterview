server {
    listen 80;
    server_name {{ nexus_docker_repo_domain }};

    access_log /var/log/nginx/nexus_docker_access.log;
    error_log  /var/log/nginx/nexus_docker_error.log;

    # Certbot needs this before the proxy catch-all.
    root /var/www/html;
    location /.well-known/acme-challenge/ {
        try_files $uri =404;
    }

    location / {
        proxy_pass         http://127.0.0.1:{{ nexus_docker_port }};
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        client_max_body_size 4096m;
        proxy_read_timeout   600s;
        proxy_send_timeout   600s;
    }
}
