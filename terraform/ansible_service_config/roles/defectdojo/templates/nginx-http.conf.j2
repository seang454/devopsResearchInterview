# /etc/nginx/sites-available/defectdojo - Ansible-managed HTTP config.
# Certbot will later add HTTPS configuration.

server {
    listen 80;
    listen [::]:80;
    server_name {{ defectdojo_domain }};

    # Required for certbot ACME challenge.
    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    # Serve static files directly.
    location /static/ {
        alias {{ defectdojo_install_dir }}/static/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    location /media/ {
        alias {{ defectdojo_install_dir }}/media/;
        expires 7d;
    }

    # Proxy all other requests to Gunicorn.
    location / {
        proxy_pass http://unix:/run/defectdojo/defectdojo.sock;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
        proxy_connect_timeout 120s;
        proxy_send_timeout 120s;
        client_max_body_size 100M;
    }
}
