---
# Domains are generated by Terraform in group_vars/nexus/terraform_domains.yml.
certbot_email: "pengseangsim@210.gmail.com"
nexus_enable_https: true
certbot_staging: true

# First run can print the initial Nexus password.
# After you change it in the UI, set the new password here or in Ansible Vault.
nexus_admin_password: "SET_AFTER_INITIAL_LOGIN"
